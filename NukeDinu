-- ==================== FLY (VELOCIDADE ATÉ 1000) ========
local function toggleFly(val)
    state.fly = val
    if flyConnection then flyConnection:Disconnect(); flyConnection = nil end
    if flyBodyVel then flyBodyVel:Destroy(); flyBodyVel = nil end
    if not val then
        local hum = getHumanoid()
        if hum then hum.PlatformStand = false end
        return
    end
    local root = getRoot()
    if not root then return end
    flyBodyVel = Instance.new("BodyVelocity")
    flyBodyVel.MaxForce = Vector3.new(1,1,1) * 1000000
    flyBodyVel.Velocity = Vector3.new(0,0,0)
    flyBodyVel.Parent = root

    flyConnection = runService.RenderStepped:Connect(function()
        if not state.fly or not flyBodyVel then return end
        local hum = getHumanoid()
        if not hum then return end
        local move = hum.MoveDirection
        local spd = state.flySpeed
        local vel = move * spd
        if userInput:IsKeyDown(Enum.KeyCode.Space) then
            vel = vel + Vector3.new(0, spd, 0)
        end
        if userInput:IsKeyDown(Enum.KeyCode.LeftShift) then
            vel = vel - Vector3.new(0, spd, 0)
        end
        flyBodyVel.Velocity = vel
    end)
end

-- ==================== NOCLIP ======================
local function toggleNoclip(val)
    state.noclip = val
    if noclipConnection then noclipConnection:Disconnect(); noclipConnection = nil end
    if val then
        noclipConnection = runService.Stepped:Connect(function()
            local char = getChar()
            if not char then return end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end)
    else
        local char = getChar()
        if not char then return end
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

-- ==================== SPEED (ATÉ 1000) =============
local function setSpeed(val)
    state.speed = val
    local hum = getHumanoid()
    if hum then
        local base = 16
        hum.WalkSpeed = base * val
    end
end

-- ==================== INFINITE JUMP ==============
local function toggleInfiniteJump(val)
    state.infiniteJump = val
    local hum = getHumanoid()
    if hum then
        hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, not val)
        hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, not val)
    end
end

-- ==================== THIRD PERSON ===============
local function toggleThirdPerson(val)
    state.thirdPerson = val
    if thirdPersonConn then thirdPersonConn:Disconnect(); thirdPersonConn = nil end
    if val then
        workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
        thirdPersonConn = runService.RenderStepped:Connect(function()
            if not state.thirdPerson then return end
            local root = getRoot()
            if not root then return end
            local cam = workspace.CurrentCamera
            local dist = state.thirdPersonDist
            local offset = root.CFrame.LookVector * -dist + Vector3.new(0, 2, 0)
            local targetPos = root.Position + offset
            cam.CFrame = CFrame.lookAt(targetPos, root.Position)
        end)
    else
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    end
end

-- ==================== ESP ========================
local function toggleESP(val)
    state.esp = val
    for _, d in ipairs(espDrawings) do d:Remove() end
    espDrawings = {}
    if espConnection then espConnection:Disconnect(); espConnection = nil end
    if not val then return end

    espConnection = runService.RenderStepped:Connect(function()
        for _, d in ipairs(espDrawings) do d:Remove() end
        espDrawings = {}
        for _, plr in ipairs(players:GetPlayers()) do
            if plr == player then continue end
            local char = plr.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then continue end

            local pos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(root.Position)
            if not onScreen then continue end

            local headPos = workspace.CurrentCamera:WorldToScreenPoint(root.Position + Vector3.new(0,3,0))
            local footPos = workspace.CurrentCamera:WorldToScreenPoint(root.Position - Vector3.new(0,3,0))
            local height = math.abs(headPos.Y - footPos.Y)
            local width = height * 0.5

            local color = (plr.Team == player.Team) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)

            local box = Drawing.new("Square")
            box.Position = Vector2.new(headPos.X - width/2, headPos.Y)
            box.Size = Vector2.new(width, height)
            box.Thickness = 2
            box.Color = color
            box.Filled = false
            table.insert(espDrawings, box)

            local name = Drawing.new("Text")
            name.Text = plr.Name
            name.Position = Vector2.new(headPos.X, headPos.Y - 18)
            name.Size = 16
            name.Color = Color3.fromRGB(255,255,255)
            name.Center = true
            name.Outline = true
            name.OutlineColor = Color3.fromRGB(0,0,0)
            table.insert(espDrawings, name)
        end
    end)
end

-- ==================== FLING =======================
local function doFling()
    local root = getRoot()
    if not root then return end
    local closest = nil
    local closestDist = math.huge
    for _, plr in ipairs(players:GetPlayers()) do
        if plr == player then continue end
        local targetChar = plr.Character
        if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then continue end
        local targetRoot = targetChar.HumanoidRootPart
        local dist = (targetRoot.Position - root.Position).Magnitude
        if dist < closestDist and dist < 100 then
            closestDist = dist
            closest = targetRoot
        end
    end
    if closest then
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1,1,1) * 1000000
        bv.Velocity = (closest.Position - root.Position).Unit * 200 + Vector3.new(0, 50, 0)
        bv.Parent = closest
        game:GetService("Debris"):AddItem(bv, 0.3)
        local hum = closest.Parent:FindFirstChild("Humanoid")
        if hum then hum:BreakJoints() end
    end
end

-- ==================== KILL NEAREST ===============
local function doKillNearest()
    local root = getRoot()
    if not root then return end
    local closest = nil
    local closestDist = math.huge
    for _, plr in ipairs(players:GetPlayers()) do
        if plr == player then continue end
        local targetChar = plr.Character
        if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then continue end
        local targetRoot = targetChar.HumanoidRootPart
        local dist = (targetRoot.Position - root.Position).Magnitude
        if dist < closestDist and dist < 200 then
            closestDist = dist
            closest = targetRoot
        end
    end
    if closest then
        local hum = closest.Parent:FindFirstChild("Humanoid")
        if hum then hum.Health = 0 end
    end
end

-- ==================== TELEPORTE POR NOME ===========
local function teleportToPlayerByName(name)
    if not name or #name < 3 then
        print("Digite pelo menos 3 letras!")
        return
    end
    local lowerName = name:lower()
    for _, plr in ipairs(players:GetPlayers()) do
        if plr == player then continue end
        if plr.Name:lower():sub(1, #lowerName) == lowerName then
            local targetChar = plr.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local root = getRoot()
                if root then
                    root.CFrame = targetChar.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                end
            end
            return
        end
    end
    print("Nenhum jogador encontrado com: " .. name)
end

