-- ==================== THIRD PERSON ======
local function toggleThirdPerson(val)
    state.thirdPerson = val
    if thirdPersonConn then thirdPersonConn:Disconnect(); thirdPersonConn = nil end
    if val then
        workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable
        thirdPersonConn = runService.RenderStepped:Connect(function()
            if not state.thirdPerson then return end
            local root = getRoot()
            if not root then return end
            local cam = workspace.CurrentCamera
            local dist = state.thirdPersonDist
            local offset = root.CFrame.LookVector * -dist + Vector3.new(0, 2, 0)
            local targetPos = root.Position + offset
            cam.CFrame = CFrame.lookAt(targetPos, root.Position)
        end)
    else
        workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
    end
end

-- ==================== ESP ======
local function toggleESP(val)
    state.esp = val
    for _, d in ipairs(espDrawings) do d:Remove() end
    espDrawings = {}
    if espConnection then espConnection:Disconnect(); espConnection = nil end
    if not val then return end

    espConnection = runService.RenderStepped:Connect(function()
        for _, d in ipairs(espDrawings) do d:Remove() end
        espDrawings = {}
        for _, plr in ipairs(players:GetPlayers()) do
            if plr == player then continue end
            local char = plr.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then continue end
            local root = char.HumanoidRootPart
            local hum = char:FindFirstChild("Humanoid")
            if not hum or hum.Health <= 0 then continue end

            local pos, onScreen = workspace.CurrentCamera:WorldToScreenPoint(root.Position)
            if not onScreen then continue end

            local headPos = workspace.CurrentCamera:WorldToScreenPoint(root.Position + Vector3.new(0,3,0))
            local footPos = workspace.CurrentCamera:WorldToScreenPoint(root.Position - Vector3.new(0,3,0))
            local height = math.abs(headPos.Y - footPos.Y)
            local width = height * 0.5

            local color = (plr.Team == player.Team) and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)

            local box = Drawing.new("Square")
            box.Position = Vector2.new(headPos.X - width/2, headPos.Y)
            box.Size = Vector2.new(width, height)
            box.Thickness = 2
            box.Color = color
            box.Filled = false
            table.insert(espDrawings, box)

            local name = Drawing.new("Text")
            name.Text = plr.Name
            name.Position = Vector2.new(headPos.X, headPos.Y - 18)
            name.Size = 16
            name.Color = Color3.fromRGB(255,255,255)
            name.Center = true
            name.Outline = true
            name.OutlineColor = Color3.fromRGB(0,0,0)
            table.insert(espDrawings, name)
        end
    end)
end

-- ==================== FLING ======
local function doFling()
    local root = getRoot()
    if not root then return end
    local closest = nil
    local closestDist = math.huge
    for _, plr in ipairs(players:GetPlayers()) do
        if plr == player then continue end
        local targetChar = plr.Character
        if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then continue end
        local targetRoot = targetChar.HumanoidRootPart
        local dist = (targetRoot.Position - root.Position).Magnitude
        if dist < closestDist and dist < 100 then
            closestDist = dist
            closest = targetRoot
        end
    end
    if closest then
        local bv = Instance.new("BodyVelocity")
        bv.MaxForce = Vector3.new(1,1,1) * 1000000
        bv.Velocity = (closest.Position - root.Position).Unit * 200 + Vector3.new(0, 50, 0)
        bv.Parent = closest
        game:GetService("Debris"):AddItem(bv, 0.3)
        local hum = closest.Parent:FindFirstChild("Humanoid")
        if hum then hum:BreakJoints() end
    end
end

-- ==================== KILL NEAREST ======
local function doKillNearest()
    local root = getRoot()
    if not root then return end
    local closest = nil
    local closestDist = math.huge
    for _, plr in ipairs(players:GetPlayers()) do
        if plr == player then continue end
        local targetChar = plr.Character
        if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then continue end
        local targetRoot = targetChar.HumanoidRootPart
        local dist = (targetRoot.Position - root.Position).Magnitude
        if dist < closestDist and dist < 200 then
            closestDist = dist
            closest = targetRoot
        end
    end
    if closest then
        local hum = closest.Parent:FindFirstChild("Humanoid")
        if hum then hum.Health = 0 end
    end
end

-- ==================== TELEPORTE ======
local function teleportToPlayerByName(name)
    if not name or #name < 3 then
        showNotification("Digite pelo menos 3 letras!", Color3.fromRGB(255, 100, 100))
        return
    end
    local lowerName = name:lower()
    for _, plr in ipairs(players:GetPlayers()) do
        if plr == player then continue end
        if plr.Name:lower():sub(1, #lowerName) == lowerName then
            local targetChar = plr.Character
            if targetChar and targetChar:FindFirstChild("HumanoidRootPart") then
                local root = getRoot()
                if root then
                    root.CFrame = targetChar.HumanoidRootPart.CFrame + Vector3.new(0, 3, 0)
                    showNotification("Teleportado para " .. plr.Name, Color3.fromRGB(0, 255, 200))
                end
            end
            return
        end
    end
    showNotification("Nenhum jogador encontrado: " .. name, Color3.fromRGB(255, 100, 100))
end

