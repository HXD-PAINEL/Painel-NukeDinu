local function applyTheme(themeName)
    state.currentTheme = themeName
    local theme = themes[themeName] or themes.roxo

    if not mainFrame then return end

    mainFrame.BackgroundColor3 = theme.bg
    mainFrame.BorderColor3 = theme.border

    for _, child in ipairs(mainFrame:GetChildren()) do
        if child.Name == "BorderTop" or child.Name == "BorderBottom" or
           child.Name == "BorderLeft" or child.Name == "BorderRight" then
            child.BackgroundColor3 = theme.accent
        end
    end

    for _, child in ipairs(mainFrame:GetDescendants()) do
        if child:IsA("TextButton") then
            if child.Name == "btnInicio" or child.Name == "btnMovimento" or
               child.Name == "btnVisual" or child.Name == "btnCombate" or
               child.Name == "btnTeleporte" or child.Name == "btnConfig" then
                if child.BackgroundColor3 ~= theme.accent2 then
                    child.BackgroundColor3 = theme.btnBg
                end
            end
        end
    end

    for _, btn in ipairs(themeButtons) do
        if btn then
            local name = btn.Name
            if name == "themeRoxo" then
                btn.BackgroundColor3 = themeName == "roxo" and theme.accent or theme.btnBg
            elseif name == "themePreto" then
                btn.BackgroundColor3 = themeName == "preto" and theme.accent or theme.btnBg
            elseif name == "themeCinza" then
                btn.BackgroundColor3 = themeName == "cinza" and theme.accent or theme.btnBg
            end
        end
    end
end

